#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>

/ {
    behaviors {
        HMShiftR: HMShiftR {
            compatible = "zmk,behavior-hold-tap";
            label = "HMSHIFTR";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            hold-while-undecided;
            hold-trigger-key-positions = <53 52 51 50 36 0 1 12 13 14 15 16 17 24 25 26 27 28 29 38 39 40 41 42 2 3 4 5 37>;
            hold-trigger-on-release;
        };

        HMShiftL: HMShiftL {
            compatible = "zmk,behavior-hold-tap";
            label = "HMSHIFTL";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            hold-while-undecided;
            hold-trigger-on-release;
            hold-trigger-key-positions = <6 7 8 9 10 11 18 19 20 21 22 23 30 31 32 33 34 35 44 45 46 47 48 49 55 56 57 43 54>;
        };

        HMR: HMR {
            compatible = "zmk,behavior-hold-tap";
            label = "HMR";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            hold-while-undecided;
            hold-trigger-key-positions = <53 52 51 50 36 0 1 12 13 14 15 16 17 24 25 26 27 28 29 38 39 40 41 42 2 3 4 5 37>;
            hold-trigger-on-release;
            flavor = "tap-preferred";
        };

        HML: HML {
            compatible = "zmk,behavior-hold-tap";
            label = "HML";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            hold-while-undecided;
            hold-trigger-on-release;
            hold-trigger-key-positions = <6 7 8 9 10 11 18 19 20 21 22 23 30 31 32 33 34 35 44 45 46 47 48 49 55 56 57 43 54>;
            flavor = "tap-preferred";
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            // ------------------------------------------------------------------------------------------------------------
            // |  ESC  |  1  |  2  |  3   |  4   |  5   |                   |  6   |  7    |  8    |  9   |   0   |   `   |
            // |  TAB  |  Q  |  W  |  E   |  R   |  T   |                   |  Y   |  U    |  I    |  O   |   P   |   -   |
            // |  CTRL |  A  |  S  |  D   |  F   |  G   |                   |  H   |  J    |  K    |  L   |   ;   |   '   |
            // | SHIFT |  Z  |  X  |  C   |  V   |  B   |   "["  |  |  "]"  |  N   |  M    |  ,    |  .   |   /   | SHIFT |
            //                     | ALT  | GUI  | LOWER|  SPACE |  | ENTER | RAISE| BSPC  | GUI   |

            display-name = "Base";
            bindings = <
&trans     &kp N1  &kp N2  &kp N3     &kp N4    &kp N5                                &kp N6              &kp N7     &kp N8     &kp N9   &kp N0    &kp GRAVE
&kp TAB    &kp Q   &kp W   &kp E      &kp R     &kp T                                 &kp Y               &kp U      &kp I      &kp O    &kp P     &kp MINUS
&kp ESC    &kp A   &kp S   &kp D      &kp F     &kp G                                 &kp H               &kp J      &kp K      &kp L    &kp SEMI  &kp SQT
&kp LSHFT  &kp Z   &kp X   &kp C      &kp V     &kp B     &kp LBKT       &kp RBKT     &kp N               &kp M      &kp COMMA  &kp DOT  &kp FSLH  &trans
                           &kp LCTRL  &kp LALT  &kp LCMD  &lt 1 SPACE    &lt 2 ENTER  &mt RCMD BACKSPACE  &kp LCTRL  &kp DEL
            >;
        };

        symbol_layer {
            // ------------------------------------------------------------------------------------------------------------
            // | BTCLR | BT1 | BT2 |  BT3 |  BT4 |  BT5 |                   |      |       |       |      |       |       |
            // |  F1   |  F2 |  F3 |  F4  |  F5  |  F6  |                   |  F7  |  F8   |  F9   |  F10 |  F11  |  F12  |
            // |   `   |  !  |  @  |  #   |  $   |  %   |                   |  ^   |  &    |  *    |  (   |   )   |   ~   |
            // |       |     |     |      |      |      |        |  |       |      |  _    |  +    |  {   |   }   |  "|"  |
            //                     |      |      |      |        |  |       |      |       |       |

            display-name = "Lower";
            bindings = <
&kp RG(LC(Q))  &trans    &trans  &trans           &trans      &trans                             &trans     &trans            &trans             &trans         &trans        &trans
&trans         &trans    &trans  &kp LT           &kp GT      &kp COLON                          &trans     &kp LPAR          &kp RPAR           &kp UNDER      &kp KP_PLUS   &trans
&kp GRAVE      &kp EXCL  &kp AT  &kp HASH         &kp DOLLAR  &kp PRCNT                          &kp CARET  &kp LEFT_BRACE    &kp RIGHT_BRACE    &kp EQUAL      &kp QUESTION  &kp TILDE
&trans         &trans    &trans  &kp KP_MULTIPLY  &kp AMPS    &trans     &trans    &trans        &trans     &kp LEFT_BRACKET  &kp RIGHT_BRACKET  &kp BACKSLASH  &kp PIPE      &trans
                                 &trans           &trans      &trans     &trans    &lt 3 RETURN  &trans     &trans            &trans
            >;
        };

        function_layer {
            // ------------------------------------------------------------------------------------------------------------
            // |       |     |     |      |      |      |                   |      |       |       |      |       |       |
            // |   `   |  1  |  2  |  3   |  4   |  5   |                   |  6   |   7   |   8   |  9   |   0   |       |
            // |   F1  |  F2 |  F3 |  F4  |  F5  |  F6  |                   |      |   <-  |   v   |  ^   |  ->   |       |
            // |   F7  |  F8 |  F9 |  F10 |  F11 |  F12 |        |  |       |  +   |   -   |   =   |  [   |   ]   |   \   |
            //                     |      |      |      |        |  |       |      |       |       |

            display-name = "Raise";
            bindings = <
&trans  &kp C_BRIGHTNESS_DEC  &kp C_BRIGHTNESS_INC  &trans  &trans  &trans                         &kp C_PREV  &kp C_PLAY_PAUSE  &kp C_NEXT  &kp C_MUTE  &kp C_VOL_DN  &kp C_VOL_UP
&trans  &kp F1                &kp F2                &kp F3  &kp F4  &kp F5                         &kp F6      &kp F7            &kp F8      &kp F9      &kp F10       &kp F11
&trans  &trans                &trans                &trans  &trans  &trans                         &kp LEFT    &kp DOWN          &kp UP      &kp RIGHT   &trans        &kp F12
&trans  &trans                &trans                &trans  &trans  &trans  &trans         &trans  &trans      &trans            &trans      &trans      &trans        &trans
                                                    &trans  &trans  &trans  &lt 4 SPACE    &trans  &trans      &trans            &trans
            >;
        };

        app_layer {
            bindings = <
&bt BT_CLR  &bt BT_SEL 0           &bt BT_SEL 1           &bt BT_SEL 2           &bt BT_SEL 3           &bt BT_SEL 4                                                                                  &trans                 &trans                 &trans                     &trans                      &trans                         &trans
&trans      &kp LS(LA(LC(LG(Q))))  &kp LS(LA(LC(LG(W))))  &kp LS(LA(LC(LG(E))))  &kp LS(LA(LC(LG(R))))  &kp LS(LA(LC(LG(T))))                                                                         &kp LS(LA(LC(LG(Y))))  &kp LS(LA(LC(LG(U))))  &kp LS(LA(LC(LG(I))))      &kp LS(LA(LC(LG(O))))       &kp LS(LA(LC(LG(P))))          &trans
&trans      &kp LS(LA(LC(LG(A))))  &kp LS(LC(LA(LG(S))))  &kp LS(LC(LA(LG(D))))  &kp LS(LC(LA(LG(F))))  &kp LS(LC(LA(LG(G))))                                                                         &kp LS(LC(LA(LG(H))))  &kp LS(LC(LA(LG(J))))  &kp LS(LC(LA(LG(K))))      &kp LS(LC(LA(LG(L))))       &kp LS(LC(LA(LG(SEMICOLON))))  &trans
&trans      &kp LS(LC(LA(LG(Z))))  &kp LS(LC(LA(LG(X))))  &kp LS(LC(LA(LG(C))))  &kp LS(LC(LA(LG(V))))  &kp LS(LA(LC(LG(B))))  &kp LS(LA(LC(LG(LEFT_BRACKET))))    &kp LS(LA(LC(LG(RIGHT_BRACKET))))  &kp LS(LA(LC(LG(N))))  &kp LS(LC(LA(LG(M))))  &kp LS(LC(LA(LG(COMMA))))  &kp LS(LC(LA(LG(PERIOD))))  &kp LS(LC(LA(LG(SLASH))))      &trans
                                                          &trans                 &trans                 &trans                 &trans                              &trans                             &trans                 &trans                 &trans
            >;

            label = "App";
        };

        mouse_layer {
            bindings = <
&trans  &trans  &trans  &trans  &trans  &trans                    &trans          &trans          &trans        &trans           &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans                    &msc SCRL_LEFT  &msc SCRL_DOWN  &msc SCRL_UP  &msc SCRL_RIGHT  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans                    &mmv MOVE_LEFT  &mmv MOVE_DOWN  &mmv MOVE_UP  &mmv MOVE_RIGHT  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans    &trans  &trans          &mkp LCLK       &mkp RCLK     &trans           &trans  &trans
                        &trans  &trans  &trans  &trans    &trans  &trans          &trans          &trans
            >;
        };
    };
};
